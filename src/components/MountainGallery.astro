---
import { mountainGalleryImages } from "../data/wixImages";
---

<section class="gallery-section section-space" aria-labelledby="gallery-heading">
  <div class="container gallery-header">
    <p class="eyebrow">Rockies golf</p>
    <h2 id="gallery-heading" class="section-title">See the course against the mountains</h2>
    <p class="lead gallery-lead">
      Stanley Thompson routed these holes through lakes, forest, and sky — a public course that feels like a private expedition into the Canadian Rockies.
    </p>
  </div>

  <div class="gallery-full">
    <ul class="gallery-grid">
      {mountainGalleryImages.map((item) => (
        <li class="gallery-cell">
          <figure class="gallery-fig">
            <img
              src={item.src}
              alt={item.alt}
              width="1600"
              height="1067"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .gallery-header {
    text-align: center;
    max-width: 62ch;
    margin-inline: auto;
    margin-bottom: clamp(1.75rem, 4vw, 2.5rem);
  }

  .gallery-lead {
    margin-bottom: 0;
  }

  .gallery-full {
    width: 100%;
    max-width: min(1400px, 100%);
    margin-inline: auto;
    padding-inline: clamp(0.75rem, 2vw, 1.5rem);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.65rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .gallery-cell {
    margin: 0;
  }

  .gallery-fig {
    margin: 0;
    height: 100%;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    aspect-ratio: 3 / 2;
  }

  .gallery-fig img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    filter: saturate(1.08) contrast(1.04);
    transition:
      transform 0.45s ease,
      filter 0.35s ease;
  }

  .gallery-fig:hover img {
    transform: scale(1.03);
    filter: saturate(1.12) contrast(1.06);
  }

  @media (max-width: 900px) {
    .gallery-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 520px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
