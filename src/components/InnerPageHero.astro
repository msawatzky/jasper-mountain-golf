---
import { pageHeroBySlug, type InnerPageHeroSlug } from "../data/pageHeroes";

interface Props {
  title: string;
  eyebrow?: string;
  tagline?: string;
  /** Matches jaspermountaingolf.com route — uses that page’s hero photo. */
  page: InnerPageHeroSlug;
}

const { title, eyebrow, tagline, page } = Astro.props;
const image = pageHeroBySlug[page];
---

<section
  class="inner-hero"
  aria-label={title}
  style={`background-image: linear-gradient(180deg, rgba(10, 38, 36, 0.24) 0%, rgba(8, 26, 25, 0.14) 34%, rgba(8, 26, 25, 0.26) 55%, rgba(6, 22, 21, 0.68) 82%, rgba(5, 20, 19, 0.9) 100%), url('${image}')`}
>
  <div class="inner-hero-overlay">
    <div class="container inner-hero-inner">
      {eyebrow && <p class="eyebrow inner-eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {tagline && <p class="inner-tagline">{tagline}</p>}
    </div>
  </div>
</section>

<style>
  .inner-hero {
    position: relative;
    width: 100%;
    min-height: min(62vh, 820px);
    background-color: #0c2f2e;
    background-size: cover;
    background-position: center 42%;
    background-repeat: no-repeat;
    display: grid;
    align-items: center;
  }

  .inner-hero-overlay {
    width: 100%;
    padding-block: clamp(4.5rem, 12vw, 7.5rem);
  }

  .inner-hero-inner {
    position: relative;
    width: min(1120px, calc(100% - 3rem));
    margin-inline: auto;
    text-align: center;
  }

  .inner-eyebrow {
    margin-bottom: 0.75rem;
    color: rgba(214, 177, 109, 0.96);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.55);
  }

  h1 {
    margin: 0 0 0.85rem;
    font-size: clamp(2rem, 5vw, 3.35rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.08;
    color: #f7fbfa;
    max-width: min(22ch, 100%);
    margin-inline: auto;
    text-wrap: balance;
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.55),
      0 5px 32px rgba(0, 0, 0, 0.42);
  }

  .inner-tagline {
    margin: 0 auto;
    max-width: 40ch;
    font-size: clamp(1.02rem, 2vw, 1.2rem);
    line-height: 1.65;
    color: rgba(247, 251, 250, 0.93);
    font-weight: 400;
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.48),
      0 4px 22px rgba(0, 0, 0, 0.38);
  }

  @media (max-width: 640px) {
    .inner-hero {
      min-height: min(52vh, 560px);
      background-position: center center;
    }
  }
</style>
