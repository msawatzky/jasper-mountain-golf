---
import { heroImages } from "../data/wixImages";

const imgClubhouse = heroImages.clubhouse;
const imgBearsDen = heroImages.bearsDen;
const imgLessons = heroImages.lessons;
---

<section class="section-space">
  <div class="container intro-inner">
    <p class="eyebrow">Centennial legacy</p>
    <h2 class="section-title">Where the Rockies meet every fairway</h2>
    <p class="lead">
      Jasper National Park surrounds every hole — glaciers on the horizon, forests at your shoulder, and Thompson&apos;s bunkers and greens laid into the land as if the
      mountains themselves sketched the routing. Our centennial story continues here: timeless strategy, panoramic views, and a sense of place you&apos;ll only find
      this high in the Canadian Rockies.
    </p>
  </div>
</section>

<section class="film-strip section-space">
  <div class="container cards">
    <article class="card">
      <div class="card-media">
        <img
          src={imgClubhouse}
          alt="Golf Clubhouse — Fairmont Jasper Park Lodge"
          width="2172"
          height="1188"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="card-body">
        <h3>Golf Clubhouse</h3>
        <p>
          Picturesque views of the 18th hole set the stage for a memorable afternoon. Coffee, instruction, apparel, and warm hospitality are all here to prepare you for a successful round.
        </p>
      </div>
    </article>

    <article class="card">
      <div class="card-media">
        <img
          src={imgBearsDen}
          alt="The Bear's Den golf simulator at Jasper Park Lodge"
          width="3200"
          height="2000"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="card-body">
        <h3>The Bear's Den</h3>
        <p>
          Jasper's first golf simulator offers over 30 virtual courses in exceptional realism. Perfect for family game nights, events, and winter practice sessions with curated food and beverage service.
        </p>
      </div>
    </article>

    <article class="card">
      <div class="card-media">
        <img
          src={imgLessons}
          alt="Golf instruction and play beneath the Rockies at Jasper Park Lodge"
          width="3024"
          height="1654"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="card-body">
        <h3>Clinics &amp; Lessons</h3>
        <p>
          Perfect your game with guidance from trained golf professionals through private lessons and small-group clinics designed for every skill level.
        </p>
      </div>
    </article>
  </div>
</section>

<style>
  .intro-inner {
    text-align: center;
    max-width: 72ch;
    margin-inline: auto;
  }

  .intro-inner .lead {
    margin-inline: auto;
  }

  .film-strip {
    background: linear-gradient(
      180deg,
      rgba(14, 62, 60, 0.05) 0%,
      rgba(14, 62, 60, 0.01) 100%
    );
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.15rem;
  }

  .card {
    margin: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: clip;
    box-shadow: var(--shadow-soft);
    min-height: 100%;
  }

  .card-media {
    height: clamp(200px, 30vw, 280px);
    overflow: hidden;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    filter: saturate(1.06) contrast(1.03);
    transition: filter 0.35s ease;
  }

  .card:hover .card-media img {
    filter: saturate(1.1) contrast(1.05);
  }

  .card-body {
    padding: 1.3rem 1.25rem 1.4rem;
  }

  h3 {
    margin: 0 0 0.75rem;
    font-size: 1.25rem;
  }

  .card p {
    margin: 0;
    color: var(--color-text-soft);
    line-height: 1.75;
  }

  @media (max-width: 980px) {
    .cards {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
