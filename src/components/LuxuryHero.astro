---
import { chronoGolfTeeTimesUrl } from "../data/site";
import { pageHeroBySlug } from "../data/pageHeroes";

interface Props {
  /** Full viewport hero (homepage under transparent header). */
  fullViewport?: boolean;
}

const { fullViewport = false } = Astro.props;

/** Homepage hero — fairway, water, and Rockies (Wix CDN). */
const heroImage = pageHeroBySlug.home;
const bookNowUrl = chronoGolfTeeTimesUrl;
const stayPlayUrl = "/vacation-packages";
---

<section
  class:list={["hero", fullViewport && "hero--full-viewport"]}
  style={`background-image: linear-gradient(180deg, rgba(10, 38, 36, 0.22) 0%, rgba(8, 26, 25, 0.12) 30%, rgba(8, 26, 25, 0.22) 52%, rgba(6, 22, 21, 0.62) 78%, rgba(5, 20, 19, 0.88) 100%), url('${heroImage}')`}
>
  <div class="hero-overlay">
    <div class="container hero-content">
      <p class="eyebrow eyebrow--photo">Fairmont Jasper Park Lodge Golf Club</p>
      <h1>Canada's #1 Resort Course</h1>
      <p class="hero-copy">
        Mountain golf at its finest — Stanley Thompson fairways beneath the Rockies. Since 1925, this course has offered what few places can: wild peaks, still water,
        and a round you&apos;ll replay in your mind long after the last putt drops.
      </p>
      <div class="hero-actions">
        <a
          href={bookNowUrl}
          class="button button-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Book Now
        </a>
        <a href={stayPlayUrl} class="button button-secondary">Stay &amp; Play</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: min(92vh, 840px);
    width: 100%;
    background-size: cover;
    background-position: center;
    display: grid;
    align-items: center;
  }

  .hero.hero--full-viewport {
    min-height: 100vh;
    min-height: 100dvh;
    min-height: 100svh;
    width: 100%;
    max-width: none;
    margin: 0;
    box-sizing: border-box;
  }

  .hero.hero--full-viewport .hero-overlay {
    padding-top: max(clamp(5rem, 10vw, 8rem), 5.25rem);
    padding-bottom: clamp(3rem, 8vw, 5rem);
  }

  .hero-overlay {
    width: 100%;
    padding-block: clamp(5rem, 10vw, 8rem);
  }

  .hero-content {
    color: #f7fbfa;
    max-width: 820px;
    margin-inline: auto;
    text-align: center;
  }

  h1 {
    margin: 0 0 1.2rem;
    font-size: clamp(2.3rem, 6vw, 4.8rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.55),
      0 6px 36px rgba(0, 0, 0, 0.45);
  }

  .hero-copy {
    margin: 0 auto 1.8rem;
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.85;
    max-width: 62ch;
    color: rgba(247, 251, 250, 0.94);
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.5),
      0 4px 24px rgba(0, 0, 0, 0.4);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .hero-actions .button-secondary {
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.45);
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.22);
  }
</style>
