---
import { chronoGolfTeeTimesUrl } from "../data/site";
import { heroImages } from "../data/wixImages";

const heroImage = heroImages.home;
const bookNowUrl = chronoGolfTeeTimesUrl;
const stayPlayUrl = "/vacation-packages";
---

<section
  class="hero"
  style={`background-image: linear-gradient(to right, rgba(8, 30, 29, 0.8), rgba(9, 37, 36, 0.55)), url('${heroImage}')`}
>
  <div class="hero-overlay">
    <div class="container hero-content">
      <p class="eyebrow">Fairmont Jasper Park Lodge Golf Club</p>
      <h1>Canada's #1 Resort Course</h1>
      <p class="hero-copy">
        Exactly where you're meant to play for more than a century. Since 1925, golfers have played this historic Stanley Thompson design surrounded by the Canadian Rockies.
      </p>
      <div class="hero-actions">
        <a
          href={bookNowUrl}
          class="button button-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Book Now
        </a>
        <a href={stayPlayUrl} class="button button-secondary">Stay &amp; Play</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: min(92vh, 840px);
    width: 100%;
    background-size: cover;
    background-position: center;
    display: grid;
    align-items: center;
  }

  .hero-overlay {
    width: 100%;
    padding-block: clamp(5rem, 10vw, 8rem);
  }

  .hero-content {
    color: #f7fbfa;
    max-width: 820px;
    margin-inline: auto;
    text-align: center;
  }

  .hero-content .eyebrow {
    color: rgba(214, 177, 109, 0.95);
  }

  h1 {
    margin: 0 0 1.2rem;
    font-size: clamp(2.3rem, 6vw, 4.8rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .hero-copy {
    margin: 0 auto 1.8rem;
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.85;
    max-width: 62ch;
    color: rgba(247, 251, 250, 0.9);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
