---
import "../styles/theme.css";
import SiteHeader from "../components/SiteHeader.astro";

interface Props {
  title: string;
  description?: string;
  /** Homepage: full-bleed hero under a transparent header; header gains a bar after scroll. */
  homeImmersive?: boolean;
}

const {
  title,
  description = "Canada's #1 resort golf course — Stanley Thompson design at Fairmont Jasper Park Lodge, Jasper National Park.",
  homeImmersive = false,
} = Astro.props;
const fullTitle =
  title === "Home"
    ? "Fairmont Jasper Park Lodge Golf Club"
    : `${title} | Fairmont Jasper Park Lodge Golf Club`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
  </head>
  <body class:list={[homeImmersive && "home-immersive"]}>
    <SiteHeader />
    <main>
      <slot />
    </main>
    {homeImmersive && (
      <script is:inline>
        (function () {
          var threshold = 40;
          function sync() {
            document.body.classList.toggle("header-solid", window.scrollY > threshold);
          }
          sync();
          window.addEventListener("scroll", sync, { passive: true });
        })();
      </script>
    )}
  </body>
</html>
